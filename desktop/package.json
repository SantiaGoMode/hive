{
  "name": "hive-desktop",
  "version": "1.0.0",
  "description": "Hive desktop app — Electron shell around the Hive server + client",
  "main": "main.js",
  "author": "Cris Santiago",
  "repository": {
    "type": "git",
    "url": "https://github.com/SantiaGoMode/hive.git",
    "directory": "desktop"
  },
  "private": true,
  "scripts": {
    "dev": "electron .",
    "stage": "node scripts/stage.js",
    "dist": "npm run stage && electron-builder",
    "dist:publish": "npm run stage && electron-builder --publish always"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3"
  }
}
