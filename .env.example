# Hive environment variables (issue #36)
#
# Copy to `.env` and fill in only what you need. Hive runs fully local with just
# Ollama — NO keys are required for local-only use. Cloud provider keys, the
# gateway, ngrok, and GitHub are all optional.
#
# Precedence: for secrets, an environment variable WINS over the value stored in
# Settings (the DB). Settings can also hold an `env:NAME` reference that resolves
# to the named env var at read time. Names are inventoried in server/lib/config.js.
#
# Never commit your real `.env` — only this example (names + placeholders) is tracked.

# ── Server (operational) ──────────────────────────────────────────────────────
# PORT=3001                          # HTTP port
# HIVE_HOME=~/.hive                  # data directory (sessions, sqlite, agents)
# HIVE_DB_PATH=~/.hive/hive.db       # sqlite path (defaults under HIVE_HOME)

# ── API access control ────────────────────────────────────────────────────────
# HIVE_AUTH_TOKEN=                   # require this token on /api requests (else open on localhost)
# HIVE_ALLOWED_ORIGINS=              # extra allowed CORS/WS origins, comma-separated
# HIVE_MUTATION_RATE_LIMIT=120       # max mutating requests per window
# HIVE_MUTATION_RATE_WINDOW_MS=60000 # rate-limit window in ms

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info                     # debug | info | warn | error | silent
# LOG_SWALLOWED=1                    # set to 0 to silence swallowed-error logs

# ── Cloud model providers (optional) ──────────────────────────────────────────
# Default: paste keys in Settings → Model providers (stored in the 0600 local DB).
# Env vars here override Settings. Optional hardening: use the LLM gateway below
# so Hive never holds these keys at all.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ── LLM gateway (optional; LiteLLM proxy that holds the real provider keys) ────
# LLM_GATEWAY_URL=http://localhost:4000/v1
# LLM_GATEWAY_KEY=                   # gateway master/virtual key

# ── Web search (optional) ─────────────────────────────────────────────────────
# BRAVE_API_KEY=

# ── ngrok public tunnel (optional) ────────────────────────────────────────────
# NGROK_AUTHTOKEN=

# ── GitHub (optional; for the colony GitHub board / PRs / issue comments) ─────
# Resolved in order: github_token setting → GITHUB_TOKEN → GITHUB_PERSONAL_ACCESS_TOKEN
# → GH_TOKEN → `gh auth token` (GitHub CLI). Set any ONE, or just run `gh auth login`.
# GITHUB_TOKEN=
# GITHUB_PERSONAL_ACCESS_TOKEN=
# GH_TOKEN=
